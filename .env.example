# Root .env — used by docker-compose.
# Copy to .env and fill in real values. Never commit .env.

# ── Required ──────────────────────────────────────────────────────────────────
DB_PASSWORD=use_a_strong_random_password
SECRET_KEY=replace_with_64_char_hex_secret
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ── Domain (Caddy uses this for automatic TLS) ────────────────────────────────
DOMAIN=yourdomain.com
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ── LLM Providers (at least one required) ────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Ollama (optional — private VPS) ──────────────────────────────────────────
# OLLAMA_BASE_URL=http://your-vps-ip:11434
# OLLAMA_MODEL=llama3.2:3b

# ── Optional overrides ────────────────────────────────────────────────────────
# GOOGLE_CLIENT_SECRET=   # not needed for ID-token flow
