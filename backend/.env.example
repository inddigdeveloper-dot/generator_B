# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost/gmb_review

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_hex_string

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── LLM Provider ────────────────────────────────────────────────────────────
# Options: gemini | ollama | openai_compat
LLM_PROVIDER=gemini

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Ollama (private VPS) — set LLM_PROVIDER=ollama to use
# OLLAMA_BASE_URL=http://your-vps-ip:11434
# OLLAMA_MODEL=llama3.2:3b

# OpenAI-compatible server (vLLM, LM Studio, etc.) — set LLM_PROVIDER=openai_compat
# OPENAI_COMPAT_URL=http://your-vps-ip:8000/v1
# OPENAI_COMPAT_KEY=none
# OPENAI_COMPAT_MODEL=review-gen

# ── Optional Infra ───────────────────────────────────────────────────────────
# Redis for shared rate-limit counters across multiple workers
# REDIS_URL=redis://localhost:6379/0
